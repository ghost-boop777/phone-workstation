rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Only these signed-in Google accounts may touch any data.
    // Add/remove emails here (lowercase) to grant/revoke shared-list access.
    function allowed() {
      return request.auth != null && request.auth.token.email in [
        'helloleads2@gmail.com',
        'thalableedblue@gmail.com'
      ];
    }

    // Shared master list (owned numbers), sharded into documents of arrays.
    match /master/{doc} {
      allow read, write: if allowed();
    }

    // Shared batch history (one doc per saved batch: counts, savings, scrub).
    match /batches/{doc} {
      allow read, write: if allowed();
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
