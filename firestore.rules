rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Founders: hardcoded root admins, always allowed (safe even before any config doc exists).
    function isFounder() {
      return request.auth != null && request.auth.token.email in [
        'helloleads2@gmail.com',
        'thalableedblue@gmail.com'
      ];
    }
    function cfgExists() { return exists(/databases/$(database)/documents/config/allowlist); }
    function inAllowlist() {
      return cfgExists() && request.auth.token.email in get(/databases/$(database)/documents/config/allowlist).data.emails;
    }
    // Allowed = a founder, OR a signed-in user added to the self-serve allowlist.
    function allowed() { return isFounder() || (request.auth != null && inAllowlist()); }

    // Self-serve allowlist: any signed-in user may READ it (to check themselves on login);
    // only founders may EDIT it.
    match /config/allowlist {
      allow read:  if request.auth != null;
      allow write: if isFounder();
    }

    // Race-safe packet number counter — incremented in a transaction.
    match /config/packet_counter {
      allow read, write: if allowed();
    }

    // Per-client DNC-Sent lists (numbers already sent to a given client),
    // sharded into documents of arrays tagged with { client }.
    match /dnc/{doc} {
      allow read, write: if allowed();
    }

    // Recipient/client roster used by the DNC-Sent dropdown.
    match /config/clients {
      allow read, write: if allowed();
    }

    // Legacy master list (kept readable so old data can be cleaned up).
    match /master/{doc} {
      allow read, write: if allowed();
    }

    // Shared batch history (one doc per saved batch: counts, scrub).
    match /batches/{doc} {
      allow read, write: if allowed();
    }

    // Lead Bank packet index (metadata only; the lead files live in Google Drive).
    match /packets/{doc} {
      allow read, write: if allowed();
    }

    // Everything else is denied.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
