{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      "**/.git/**",
      ".github/**",
      "**/.github/**",
      "**/node_modules/**",
      "README.md"
    ],
    "headers": [
      {
        "source": "ofcom-blocks.json",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ]
  }
}
